# PolancoWatch Environment Configuration

# --- Backup Configuration ---
# On Linux Docker, set this to your backup volume name (default: polancowatch_backups)
BACKUP_HOST_PATH=polancowatch_backups

# --- Security ---
# Change this to a long random string (at least 32 characters)
JWT_KEY=ChangeMeThisIsASecretKey1234567890
ADMIN_INITIAL_PASSWORD=

# --- Web / Frontend ---
# Ports to expose locally
PORT=5173
API_PORT=5246

# Public URLs used by OAuth/CORS and the built frontend
APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:5246
ALLOWED_HOSTS=*

# --- Google Drive Cloud Backup ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_DEFAULT_FOLDER_ID=

# --- Notifications (Optional) ---

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
